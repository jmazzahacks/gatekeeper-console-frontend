# ==============================================================================
# Public (browser-shipped) — only NEXT_PUBLIC_* vars below are baked into the
# client bundle at build time. Never put secrets here.
# ==============================================================================

# Aegis API URL — used directly from the browser for bearer-gated calls
# (refresh, logout, /me, confirm-email-change). The six tenant-key-gated
# calls (login, register, verify-email, password reset) go through the
# gatekeeper backend instead, see NEXT_PUBLIC_GATEKEEPER_API_URL below.
NEXT_PUBLIC_AEGIS_API_URL=https://aegis.example.com

# Display-only branding shown in the UI. No security significance.
NEXT_PUBLIC_SITE_NAME=gatekeeper
NEXT_PUBLIC_SITE_DOMAIN=gatekeeper.example.com

# Gatekeeper backend URL — the auth proxy (login / register / verify-email /
# password reset) calls this. In production this is same-origin behind nginx,
# so a relative path works. For local dev, see DEV_GATEKEEPER_PROXY below.
NEXT_PUBLIC_GATEKEEPER_API_URL=https://gatekeeper.example.com

# ==============================================================================
# Local development only — read at server runtime, NOT shipped to the browser.
# ==============================================================================

# When set, the Next.js dev server proxies /api/admin/* and /api/auth/* to
# this URL. Use this to develop against a remote gatekeeper backend without
# fighting CORS preflights from localhost:3000.
# DEV_GATEKEEPER_PROXY=https://gatekeeper.example.com

# DEBUG_LOCAL=true sends logs to stdout. Omit or set to false to send to Loki.
DEBUG_LOCAL=true

# Loki logging (production only — required when DEBUG_LOCAL=false)
# LOKI_URL=https://loki.example.com
# LOKI_USER=
# LOKI_PASS=
# LOKI_CA_PATH=

# Aegis webhook secret — for Server Actions / route handlers that verify
# incoming Aegis webhooks. Not currently used by the gatekeeper frontend
# (webhooks land on docker-backend), but reserved here for future use.
# AEGIS_WEBHOOK_SECRET=
