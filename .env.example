# Aegis Authentication API URL (browser-accessible)
# Set this to your Aegis instance URL
NEXT_PUBLIC_AEGIS_API_URL=https://aegis.example.com

# Site domain for authentication (must match aegis site configuration)
# Set this to your deployed frontend domain
NEXT_PUBLIC_SITE_DOMAIN=gatekeeper.example.com

# Logging: set DEBUG_LOCAL=true for console output, omit or set to false for Loki
DEBUG_LOCAL=true
# LOKI_URL=https://loki.example.com
# LOKI_USER=
# LOKI_PASS=
# LOKI_CA_PATH=

# Webhook secret from Aegis admin (for user provisioning)
# AEGIS_WEBHOOK_SECRET=
